{
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "cd artifacts/mashwar && npx vite build --config vite.config.ts",
  "outputDirectory": "artifacts/mashwar/dist/public",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
